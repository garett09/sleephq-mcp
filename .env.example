# SleepHQ OAuth credentials (required).
# Get these from your SleepHQ account → API settings.
SLEEPHQ_CLIENT_ID=your_client_id_here
SLEEPHQ_CLIENT_SECRET=your_client_secret_here

# OAuth scope sent to SleepHQ (default read). Widen only if the API returns 403 for your calls.
SLEEPHQ_OAUTH_SCOPE=read

# MCP HTTP endpoint protection (required unless you opt into anonymous access below).
# Use the same value in Goose / clients as header X-SleepHQ-MCP-Key.
SLEEPHQ_MCP_API_KEY=change-me-to-a-long-random-secret

# Local development only: skip MCP API key checks (never on a shared host or VPN).
SLEEPHQ_MCP_ALLOW_ANONYMOUS=false

# Default identifiers — optional, but configuring them lets the LLM omit
# these arguments when calling tools and they'll be filled from env.
# From list-teams / list-machines: team_id is NOT the CPAP machine id.
SLEEPHQ_TEAM_ID=
# CPAP machine id (e.g. AirSense from list-machines). Must NOT equal SLEEPHQ_TEAM_ID.
SLEEPHQ_CPAP_MACHINE_ID=
# O2 Ring machine id from list-machines (separate from CPAP).
SLEEPHQ_O2_MACHINE_ID=

# MCP HTTP port (default 8080).
SLEEPHQ_MCP_PORT=8080
