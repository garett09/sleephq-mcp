# SleepHQ OAuth credentials (required).
# Get these from your SleepHQ account → API settings.
SLEEPHQ_CLIENT_ID=your_client_id_here
SLEEPHQ_CLIENT_SECRET=your_client_secret_here

# OAuth scope sent to SleepHQ (default read). Widen only if the API returns 403 for your calls.
SLEEPHQ_OAUTH_SCOPE=read

# MCP HTTP endpoint protection (required unless you opt into anonymous access below).
# Use the same value in Goose / clients as header X-SleepHQ-MCP-Key.
SLEEPHQ_MCP_API_KEY=change-me-to-a-long-random-secret

# Local development only: skip MCP API key checks (never on a shared host or VPN).
SLEEPHQ_MCP_ALLOW_ANONYMOUS=false

# Default identifiers — optional, but configuring them lets the LLM omit
# these arguments when calling tools and they'll be filled from env.
# From list-teams / list-machines: team_id is NOT the CPAP machine id.
SLEEPHQ_TEAM_ID=
# CPAP machine id (e.g. AirSense from list-machines). Must NOT equal SLEEPHQ_TEAM_ID.
SLEEPHQ_CPAP_MACHINE_ID=
# O2 Ring machine id from list-machines (separate from CPAP).
SLEEPHQ_O2_MACHINE_ID=

# CPAP clock drift fallback (seconds added to EDF wall times). Prefer SleepHQ machine_date.time_offset when using date-based EDF tools.
# Set only if API time_offset is missing for your device. Measure your own drift and enter seconds here (e.g. 23m48s → 1428).
SLEEPHQ_CPAP_CLOCK_ADJUST_SECONDS=

# MCP HTTP port (default 8080).
SLEEPHQ_MCP_PORT=8080

# Parallel per-day fetches for get-comparison (default 8).
SLEEPHQ_FETCH_PARALLELISM=8

# ── OSCAR local data (optional) ──────────────────────────────────────────────
# Point OSCAR_DATA_PATH at your OSCAR backup folder to enable night_analysis.
# Default is ~/Documents/OSCAR_Data — set only if yours is elsewhere.
OSCAR_DATA_PATH=~/Documents/OSCAR_Data
# OSCAR_PROFILE_NAME and OSCAR_DEVICE_FOLDER default to auto-detect (leave blank unless you have multiple profiles/devices).
OSCAR_PROFILE_NAME=
OSCAR_DEVICE_FOLDER=

# ── Local SleepHQ mirror (optional) ──────────────────────────────────────────
# ezscript/sleephq_download.py writes local PLD/EDF files. get-sleephq-night reads these first.
# Defaults match the downloader's output locations — set only if yours differ.
SLEEPHQ_LOCAL_DATA_PATH=~/RESMED_DATA
SLEEPHQ_O2_LOCAL_PATH=~/SLEEPHQ_O2_RING
SLEEPHQ_SYNC_REPORT_PATH=~/ezscript/sync_report.json

# MCP payload limits (omit maxMinutes on get-waveform-by-date to use default).
# Tight (token-safe): 10 / 60 / 4000 / 45
# Large-context (Goose 1M): 480 / 600 / 4000 / 45 — restart ./run.sh after changes
SLEEPHQ_MCP_WAVEFORM_DEFAULT_MAX_MINUTES=10
SLEEPHQ_MCP_WAVEFORM_MAX_MINUTES_CAP=60
SLEEPHQ_MCP_WAVEFORM_MAX_SAMPLES=4000
SLEEPHQ_MCP_O2_RECOMMENDED_MAX_MINUTES=45
